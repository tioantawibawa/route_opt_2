,"saving":40.7,"avgn":13.4},{"name":"UNIT KASIHAN","region":"Yogyakarta","days":224,"act":22.76,"opt":13.56,"saving":40.4,"avgn":15.8}],"weekly":[{"week":1,"act":28.31,"opt":13.27,"days":214},{"week":2,"act":27.68,"opt":12.52,"days":1045},{"week":3,"act":34.66,"opt":15.83,"days":853},{"week":4,"act":28.96,"opt":12.52,"days":1143},{"week":5,"act":32.41,"opt":13.29,"days":1280},{"week":6,"act":33.86,"opt":14.2,"days":1055},{"week":7,"act":30.2,"opt":12.78,"days":1202},{"week":8,"act":29.4,"opt":12.95,"days":896},{"week":9,"act":28.35,"opt":12.04,"days":1228},{"week":10,"act":27.76,"opt":11.95,"days":1179},{"week":11,"act":26.12,"opt":11.69,"days":1169},{"week":12,"act":23.52,"opt":10.77,"days":523},{"week":13,"act":22.04,"opt":10.37,"days":782},{"week":14,"act":22.41,"opt":10.33,"days":685},{"week":15,"act":22.4,"opt":10.03,"days":932},{"week":16,"act":24.83,"opt":10.85,"days":963},{"week":17,"act":21.11,"opt":9.9,"days":997},{"week":18,"act":21.13,"opt":9.91,"days":688},{"week":19,"act":21.76,"opt":10.44,"days":1004},{"week":20,"act":19.33,"opt":9.75,"days":681},{"week":21,"act":21.36,"opt":9.91,"days":1022},{"week":22,"act":18.77,"opt":9.21,"days":724},{"week":23,"act":22.08,"opt":10.22,"days":714},{"week":24,"act":21.7,"opt":10.13,"days":961},{"week":25,"act":22.66,"opt":11.37,"days":201}],"example":{"uker":"UNIT SUMBANG PURWOKERTO","tgl":"2026-01-29","act":[[-7.369303,109.273976],[-7.381741,109.281996],[-7.367327,109.275551],[-7.380464,109.274104],[-7.375963,109.275911],[-7.3828,109.276913],[-7.385169,109.277515],[-7.37631,109.274426],[-7.369866,109.2748],[-7.369959,109.274616],[-7.370146,109.272938],[-7.376711,109.287808]],"opt":[[-7.369303,109.273976],[-7.369959,109.274616],[-7.369866,109.2748],[-7.370146,109.272938],[-7.367327,109.275551],[-7.375963,109.275911],[-7.37631,109.274426],[-7.380464,109.274104],[-7.3828,109.276913],[-7.385169,109.277515],[-7.381741,109.281996],[-7.376711,109.287808]],"act_km":10.21,"opt_km":4.5},"eval":{"km_dist":[{"b":"0-5","v":5437},{"b":"5-10","v":3324},{"b":"10-15","v":2839},{"b":"15-20","v":2158},{"b":"20-30","v":2890},{"b":"30+","v":5494}],"visit_dist":[{"b":"1-4","v":1664},{"b":"5-7","v":1372},{"b":"8-10","v":1244},{"b":"11-13","v":1566},{"b":"14-16","v":7876},{"b":"17+","v":8420}],"hour_hist":[{"h":6,"v":350},{"h":7,"v":2224},{"h":8,"v":11860},{"h":9,"v":23836},{"h":10,"v":36387},{"h":11,"v":29725},{"h":12,"v":24044},{"h":13,"v":26612},{"h":14,"v":28329},{"h":15,"v":32681},{"h":16,"v":34542},{"h":17,"v":30998},{"h":18,"v":23814},{"h":19,"v":12601}],"stats":{"km_mean":25.9,"km_median":14.0,"km_p90":58.4,"km_max":498.3,"legshare":31.7,"over20":37.8,"start_mean":9.6,"km_per_visit":0.98,"top25share":69.3,"severe_backtrack":13.4}}};
const fmt = n => n.toLocaleString('id-ID');
const k = DATA.kpi;

document.getElementById('h-save').textContent = k.saving_pct;

// KPI strip
const kpiDefs = [
  ['Total kunjungan',fmt(k.total_visits),k.n_mantri+' mantri · '+k.n_uker+' unit kerja'],
  ['Rata-rata rute/hari',k.avg_km_day+' <small>km</small>',k.avg_visits_day+' kunjungan per hari'],
  ['Rute optimal/hari',k.opt_km_day+' <small>km</small>','hasil model NN + 2-opt'],
  ['Total jarak terpangkas',fmt(k.km_saved_total)+' <small>km</small>','akumulasi '+fmt(k.mantri_days)+' mantri-hari'],
];
document.getElementById('kpis').innerHTML = kpiDefs.map(d=>
  `<div class="kpi"><div class="lbl">${d[0]}</div><div class="val">${d[1]}</div><div class="sub">${d[2]}</div></div>`).join('');

// Impact callout
const tripPerKm = 0.12; // estimasi liter/km motor -> keep simple, show km & capacity
document.getElementById('impact').innerHTML = [
  [k.saving_pct+'%','rata-rata jarak rute dipangkas per hari'],
  [fmt(k.km_saved_total)+' km','total jarak yang dapat dihemat dalam periode data'],
  ['+'+Math.round(k.saving_pct/100*k.avg_visits_day*10)/10,'estimasi tambahan kapasitas kunjungan/hari per mantri']
].map(x=>`<div><div class="n">${x[0]}</div><div class="l">${x[1]}</div></div>`).join('');

const NAVY='#13335c',AMBER='#e8a13a',RUST='#b3492d',TEAL='#1f8a78',MUTED='#5b6675';
const hasChart = typeof Chart !== 'undefined';
if(hasChart){Chart.defaults.font.family="'Inter',sans-serif";Chart.defaults.color=MUTED;}
function chart(id,cfg){ if(!hasChart) return; try{ new Chart(document.getElementById(id),cfg);}catch(e){console.warn('chart',id,e);} }

// Trend
chart('trend',{type:'line',
  data:{labels:DATA.weekly.map(w=>'W'+w.week),datasets:[
    {label:'Aktual',data:DATA.weekly.map(w=>w.act),borderColor:RUST,backgroundColor:'rgba(179,73,45,.08)',fill:true,tension:.35,borderWidth:2.5,pointRadius:0},
    {label:'Optimal',data:DATA.weekly.map(w=>w.opt),borderColor:TEAL,backgroundColor:'rgba(31,138,120,.08)',fill:true,tension:.35,borderWidth:2.5,pointRadius:0}
  ]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{usePointStyle:true,boxWidth:8}}},
    scales:{y:{title:{display:true,text:'km / mantri-hari'},grid:{color:'#eee'}},x:{grid:{display:false}}}}});

// Donut
const vt=k.visit_types||{penagihan:205222,pemasaran:125590,pembinaan:9573,ots:1027};
chart('donut',{type:'doughnut',
  data:{labels:['Penagihan','Pemasaran','Pembinaan','OTS / lainnya'],
    datasets:[{data:[vt.penagihan,vt.pemasaran||vt.penagihan_extracomp||0,vt.pembinaan,vt.ots||1027],
      backgroundColor:[NAVY,'#3b82c4',AMBER,'#c9b48f'],borderWidth:2,borderColor:'#fff'}]},
  options:{responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{legend:{position:'bottom',labels:{usePointStyle:true,boxWidth:8,padding:12}}}}});

// Region bar
const reg=[...DATA.region].sort((a,b)=>b.saving-a.saving);
chart('region',{type:'bar',
  data:{labels:reg.map(r=>r.name),datasets:[
    {label:'Km aktual/hari',data:reg.map(r=>r.act),backgroundColor:RUST,borderRadius:5,yAxisID:'y'},
    {label:'Km optimal/hari',data:reg.map(r=>r.opt),backgroundColor:TEAL,borderRadius:5,yAxisID:'y'},
    {label:'Penghematan %',data:reg.map(r=>r.saving),type:'line',borderColor:AMBER,borderWidth:3,pointRadius:4,pointBackgroundColor:AMBER,yAxisID:'y1'}
  ]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{usePointStyle:true,boxWidth:8}}},
    scales:{y:{position:'left',title:{display:true,text:'km'},grid:{color:'#eee'}},
      y1:{position:'right',title:{display:true,text:'%'},min:0,max:80,grid:{display:false}},x:{grid:{display:false}}}}});

// Uker table
const tbody=document.querySelector('#uktbl tbody');
function renderUk(sortKey){
  const rows=[...DATA.uker].filter(u=>u.days>=15).sort((a,b)=>b[sortKey]-a[sortKey]).slice(0,18);
  const maxS=Math.max(...rows.map(r=>r.saving));
  tbody.innerHTML=rows.map(u=>`<tr>
    <td><div style="font-weight:600">${u.name.replace('UNIT ','')}</div><div style="font-size:11px;color:var(--muted)">${u.region} · ${u.avgn} kunj/hari</div></td>
    <td class="num">${u.act}</td><td class="num" style="color:var(--teal)">${u.opt}</td>
    <td><div style="display:flex;align-items:center;gap:8px"><div class="bar" style="width:${u.saving/maxS*70}px"></div><span class="mono" style="font-weight:600;font-size:12px">${u.saving}%</span></div></td>
  </tr>`).join('');
}
renderUk('saving');
document.querySelectorAll('#uktools button').forEach(b=>b.onclick=()=>{
  document.querySelectorAll('#uktools button').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');renderUk(b.dataset.sort);});

// Map
const ex=DATA.example;
if(ex && typeof L !== 'undefined'){
  const all=ex.act;
  const lat=all.map(p=>p[0]),lon=all.map(p=>p[1]);
  const ctr=[lat.reduce((a,b)=>a+b)/lat.length,lon.reduce((a,b)=>a+b)/lon.length];
  const map=L.map('map',{scrollWheelZoom:false}).setView(ctr,14);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap, © CARTO',maxZoom:19}).addTo(map);
  L.polyline(ex.act,{color:'#b3492d',weight:3,opacity:.75,dashArray:'2,6'}).addTo(map);
  L.polyline(ex.opt,{color:'#1f8a78',weight:4,opacity:.9}).addTo(map);
  ex.opt.forEach((p,i)=>{
    L.circleMarker(p,{radius:11,fillColor:'#13335c',color:'#fff',weight:2,fillOpacity:1}).addTo(map)
      .bindTooltip(String(i+1),{permanent:true,direction:'center',className:'mk'});
  });
  map.fitBounds(L.polyline(ex.act).getBounds().pad(0.15));
}
if(ex){
  document.getElementById('mapstat').innerHTML=[
    [ex.uker.replace('UNIT ',''),'Unit kerja'],[ex.tgl,'Tanggal'],
    [ex.act_km+' km','Rute aktual'],[ex.opt_km+' km','Rute optimal'],
    [Math.round((ex.act_km-ex.opt_km)/ex.act_km*100)+'%','Penghematan']
  ].map(s=>`<div><div class="n">${s[0]}</div><div class="l">${s[1]}</div></div>`).join('');
}
const st=document.createElement('style');
st.textContent='.mk{background:transparent;border:0;box-shadow:none;color:#fff;font-weight:700;font-size:11px}.leaflet-tooltip.mk:before{display:none}';
document.head.appendChild(st);
</script>
</body>
</html>